{
  "name": "hire-me-or-roast-me-monorepo",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "concurrently \"npm run start-backend\" \"npm run start-frontend\"",
    "start-backend": "cd api && npm run dev",
    "start-frontend": "cd frontend && npm run dev",
    "install-all": "npm install && npm run install-backend && cd frontend && npm install",
    "build": "cd frontend && npm install && npm run build",
    "install-backend": "cd api && npm install"
  },
  "dependencies": {
    "@google/genai": "^1.47.0",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "mammoth": "^1.12.0",
    "multer": "^2.1.1",
    "pdf-parse": "^2.4.5"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  },
  "engines": {
    "node": "22.x"
  }
}
